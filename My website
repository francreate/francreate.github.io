<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Francesca Ray</title>
  <link rel="stylesheet" href="css/style.css">
  <style>
    /* ----- Background and General Styles ----- */
    body {
      font-family: Arial, sans-serif;
      color: white; /* text color */
      background: url('https://images.unsplash.com/photo-1501004318641-b39e6451bec6?auto=format&fit=crop&w=1600&q=80') no-repeat center center fixed;
      background-size: cover;
      margin: 0;
      padding: 0;
      text-shadow: 1px 1px 3px rgba(0, 0, 0, 0.7); /* adds contrast to text */
    }

    .container {
      max-width: 600px;
      margin: 0 auto;
      padding: 40px 20px;
      text-align: center;
      background: rgba(0, 0, 0, 0.4); /* semi-transparent overlay for readability */
      border-radius: 15px;
      box-shadow: 0 0 20px rgba(0, 0, 0, 0.5);
    }

    /* ----- Introduction ----- */
    .intro {
      font-size: 1.2em;
      margin-bottom: 30px;
    }

    .section-header h1 {
      font-size: 1.5em;
      margin-top: 40px;
      margin-bottom: 20px;
      border-bottom: 2px solid rgba(255, 255, 255, 0.6);
      display: inline-block;
      padding-bottom: 5px;
    }

    /* ----- Buttons ----- */
    .links-container {
      display: flex;
      flex-direction: column;
      gap: 10px;
      align-items: center;
    }

    .button {
      background-color: rgba(255, 255, 255, 0.2);
      color: white;
      padding: 12px 25px;
      text-decoration: none;
      border-radius: 8px;
      cursor: pointer;
      transition: background-color 0.3s, transform 0.2s;
      border: 2px solid white;
    }

    .button:hover {
      background-color: rgba(255, 255, 255, 0.5);
      transform: scale(1.05);
    }

    /* ----- Slidedown Sections ----- */
    .slidedown {
      display: none;
      margin-top: 10px;
      text-align: left;
      border: 1px solid rgba(255, 255, 255, 0.5);
      border-radius: 8px;
      padding: 15px;
      background-color: rgba(0, 0, 0, 0.5);
      width: 100%;
      box-sizing: border-box;
    }

    .description h2 {
      margin-top: 0;
    }

    .description p, .description a {
      color: white;
    }

    .external-link {
      text-decoration: underline;
      color: #ffeb3b;
    }

    .footer {
      text-align: center;
      font-size: 0.9em;
      margin-top: 40px;
      padding: 10px;
      color: white;
      text-shadow: 1px 1px 3px rgba(0, 0, 0, 0.7);
    }

    @media (max-width: 500px) {
      .intro {
        font-size: 1em;
      }

      .button {
        width: 100%;
        padding: 10px;
      }

      .container {
        padding: 30px 15px;
      }
    }
  </style>
</head>

<body>
  <div class="container">
    <!-- Introduction -->
    <div class="intro">
      I'm <strong>Francesca Ray</strong>, Communication major, hike enjoyer, and I want to travel to every continent in the world!
    </div>

    <!-- Work Section -->
    <div class="section-header">
      <h1>My Work</h1>
    </div>
    <div class="links-container">
      <div class="button toggle">Blog Post</div>
      <div class="slidedown">
        <div class="description">
          <h2>My Blog</h2>
          <p>This is my blog post!</p>
          <a href="#" class="external-link" target="_blank">Read</a>
        </div>
      </div>

      <div class="button toggle">Video</div>
      <div class="slidedown">
        <div class="description">
          <h2>My Video</h2>
          <p>This is my video!</p>
          <a href="#" class="external-link" target="_blank">Watch</a>
        </div>
      </div>

      <div class="button toggle">Podcast</div>
      <div class="slidedown">
        <div class="description">
          <h2>How VT Students Consume Different Forms of Media</h2>
          <p>This podcast compares and contrasts different grade levels and the variety of media that is consumed by them.</p>
          <a href="#" class="external-link" target="_blank">Listen</a>
        </div>
      </div>
    </div>

    <!-- About Me Section -->
    <div class="section-header">
      <h1>About Me</h1>
    </div>
    <div class="links-container">
      <a href="https://drive.google.com" class="button" target="_blank">Resume</a>
    </div>
  </div>

  <!-- Footer -->
  <div class="footer">
    <p>© Francesca Ray, 2024. Based on a design by 
      <a href="https://www.w3schools.com/howto/howto_website_create_linktree.asp" target="_blank">w3schools</a>.
    </p>
  </div>

  <!-- Optional Slider JS -->
  <script>
    // Simple toggle for slidedown sections
    document.querySelectorAll('.toggle').forEach(btn => {
      btn.addEventListener('click', () => {
        const slidedown = btn.nextElementSibling;
        slidedown.style.display = slidedown.style.display === 'block' ? 'none' : 'block';
      });
    });
  </script>
</body>

</html>
